     "@cds.ambiguous": "missing on condition?",
     "type": "cds.Association",
     "target": "ZDEMP_BTP_SRV.ETS_WORKFLOW_MESSAGESet",
     "cardinality": {
      "max": "*"
     },
     "on": [
      {
       "ref": [
        "NAV_WORKFLOW_MESSAGE",
        "ReqId"
       ]
      },
      "=",
      {
       "ref": [
        "ReqId"
       ]
      },
      "and",
      {
       "ref": [
        "NAV_WORKFLOW_MESSAGE",
        "CustomerId"
       ]
      },
      "=",
      {
       "ref": [
        "CustomerId"
       ]
      }
     ]
    }

{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "source": "^/user-api/attributes$",
      "target": "/attributes",
      "service": "sap-approuter-userapi"
    },
    {
      "source": "^/bpmworkflowruntime/v2/(.*)$",
      "target": "/public/rule/runtime/rest/v2/$1",
      "destination": "BPA",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/bpmworkflowruntime/(.*)$",
      "target": "/public/workflow/rest/$1",
      "destination": "BPA",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/api/(.*)$",
      "target": "$1",
      "service": "com.sap.spa.processautomation",
      "endpoint": "api",
      "csrfProtection": true,
      "authenticationType": "xsuaa"
     },
     {
      "source": "^/odata/v2/pcservice/(.*)$",
      "target": "/odata/v2/pcservice/$1",
      "destination": "profitcenter-srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/sap/(.*)$",
      "target": "/sap/$1",
      "destination": "DIM",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "source": "^/resources/(.*)$",
      "target": "/resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^/test-resources/(.*)$",
      "target": "/test-resources/$1",
      "authenticationType": "none",
      "destination": "ui5"
    },
    {
      "source": "^(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
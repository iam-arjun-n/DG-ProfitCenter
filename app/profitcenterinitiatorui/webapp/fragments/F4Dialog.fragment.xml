<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <SelectDialog
        id="mySelectDialog"
        noDataText="No Data!"
        search="_handleValueHelpSearch"
        confirm=".onDialogClose"
        cancel=".onDialogClose"
        title=""
        growingThreshold="10"
        items="{
			path: 'F4Model>/'
		}"
    >
        <StandardListItem
            title="{F4Model>title}"
            description="{F4Model>description}"
            info="{F4Model>info}"
            type="Active"
        />
    </SelectDialog>
</core:FragmentDefinition>
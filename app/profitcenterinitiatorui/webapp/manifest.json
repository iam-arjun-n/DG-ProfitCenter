{
  "_version": "1.59.0",
  "sap.app": {
    "id": "mdg.profitcenter.ui.profitcenterinitiatorui",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.14.1",
      "toolsId": "e6d8c22c-87f3-4000-9646-c2e93e00cca3"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v2/pcservice/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "2.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.125.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.f": {},
        "sap.suite.ui.generic.template": {},
        "sap.ui.comp": {},
        "sap.ui.generic.app": {},
        "sap.ui.table": {},
        "sap.ushell": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "mdg.profitcenter.ui.profitcenterinitiatorui.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "async": true,
        "viewPath": "mdg.profitcenter.ui.profitcenterinitiatorui.view",
        "controlAggregation": "pages",
        "controlId": "app",
        "clearControlAggregation": false
      },
      "routes": [
        {
          "name": "RouteOverView",
          "pattern": "",
          "target": [
            "TargetOverView"
          ]
        },
        {
          "name": "CreateRoute",
          "pattern": "create/{key}",
          "target": ["TargetCreateRoute"]
        },{
          "name" : "ViewRoute",
          "pattern": "view/{ReqId}",
          "target":["TargetViewRoute"]
        }
      ],
      "targets": {
        "TargetOverView": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "OverView",
          "viewName": "OverView"
        },
        "TargetCreateRoute": {
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "CreatePage",
          "viewName": "CreatePage"
        },
        "TargetViewRoute":{
          "viewType": "XML",
          "transition": "slide",
          "clearControlAggregation": false,
          "viewId": "ViewPage",
          "viewName": "ViewRequestData"
        }
      }
    },
    "rootView": {
      "viewName": "mdg.profitcenter.ui.profitcenterinitiatorui.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "MDGProfitCenter_approuter"
  }
}

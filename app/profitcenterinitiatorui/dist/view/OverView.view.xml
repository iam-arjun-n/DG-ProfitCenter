<mvc:View controllerName="mdg.profitcenter.ui.profitcenterinitiatorui.controller.OverView"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:layout="sap.ui.layout"
    xmlns:vm="sap.ui.comp.variants">
    <f:DynamicPage id="dynamicPageId" headerExpanded="{/headerExpanded}">
        
        
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
                <f:heading>
                    <Title id="_IDGenTitle8" text="Profit Center - Create Requests"/>
                </f:heading>
                <f:actions>
                    <Button id="_IDGenButton5" text="Create" type="Emphasized" press=".onCreatePress"/>
                    <Button id="_IDGenButton6" text="Change/Extend" type="Emphasized" press=".onDisplayPress"/>
                  
                </f:actions>
            </f:DynamicPageTitle>
        </f:title>

       <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader1" pinnable="true" backgroundDesign="Transparent">
                <f:content>
                    <fb:FilterBar id="filterbar" reset="onClear" clear="onClearSearch" search="onGo" showFilterConfiguration="false" useToolbar="false" showGoOnFB="true" showClearOnFB="true">
                        <fb:filterGroupItems>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem2" groupName="g1" name="A" label="Request Number" visibleInFilterBar="true">
                                <fb:control>
                                    <MultiInput name="Request Status" id="REQ" valueHelpRequest="REQHelp" showValueHelp = "true" enabled="true" editable="true">
                                    </MultiInput>
                                </fb:control>
                            </fb:FilterGroupItem>
                            <fb:FilterGroupItem id="_IDGenFilterGroupItem3" groupName="g1" name="B" label="Status" visibleInFilterBar="true">
                                <fb:control>

                                    <Select xmlns="sap.m" id="rStat" forceSelection="false">
                                        <items>
                                            <core:Item id="_IDGenItem233"
                                                xmlns:core="sap.ui.core" key="In Progress" text="In Progress"/>
                                            <core:Item id="_IDGenItem333"
                                                xmlns:core="sap.ui.core" key="Completed" text="Completed"/>
                                            <core:Item id="_IDGenItem4"
                                                xmlns:core="sap.ui.core" key="Rejected" text="Rejected"/>
                                        </items>
                                    </Select>
                                </fb:control>
                            </fb:FilterGroupItem>

                            <fb:FilterGroupItem id="fgType" groupName="g1" name="objType" label="Type" visibleInFilterBar="true">
                                <fb:control>
                                    <Select xmlns="sap.m" id="objType" forceSelection="false">
                                        <items>
                                            <core:Item id="createItem"
                                                xmlns:core="sap.ui.core" key="Create" text="Create"/>
                                            <core:Item id="modItem"
                                                xmlns:core="sap.ui.core" key="Change" text="Change"/>
                                        </items>
                                    </Select>
                                </fb:control>
                            </fb:FilterGroupItem>

                            <fb:FilterGroupItem id="fgCreatedBy" groupName="g1" name="CreatedBy" label="Created By" visibleInFilterBar="true">
                               <fb:control>
                                 <MultiInput name="Created By" id="rCreatedBy" valueHelpRequest="REQHelpCreatedBy" editable="true">
                                    </MultiInput>
                               </fb:control>
                            </fb:FilterGroupItem>


                            <fb:FilterGroupItem id="_IDGenFilterGroupItem6" groupName="g1" name="D" label="Creation Date" visibleInFilterBar="true">
                                <fb:control>
                                    <DatePicker displayFormat="dd-MM-yyyy" id="crDate"/>
                                </fb:control>
                            </fb:FilterGroupItem>

                        </fb:filterGroupItems>
                    </fb:FilterBar>
                </f:content>
            </f:DynamicPageHeader>
        </f:header>

        
        <f:content>
            <Table id="idTable"
                sticky="HeaderToolbar,ColumnHeaders"
                inset="false"
                items="{ path: 'mainServiceModel>/ETY_WORKFLOW_HEADERSet', sorter: [ { path: 'CreatedOn', descending: true } ] }"
                backgroundDesign="Solid" 
                noDataText="No Data" 
                selectionChange=".onSelectionRow" 
                mode="SingleSelectLeft" 
                alternateRowColors="true"
                class="sapFDynamicPageAlignContent"
                width="auto">
                
                <headerToolbar>
                    <Toolbar id="_IDGenToolbar">
                        <Title id="_IDGenTitle13" text="Profit Center Created" level="H2"/>
                        <ToolbarSpacer id="_IDGenToolbarSpacer"/>
                        <Button id="btnview" icon="sap-icon://detail-view" text="{i18n>view}" press=".onViewObj" enabled="false" type="Emphasized"/>
                    </Toolbar>
                </headerToolbar>
                
                <columns>
                    <Column id="_IDGenColumn26"><Text id="_IDGenText6" text="Request Number"/></Column>
                    <Column id="_IDGenColumn32"><Text id="_IDGenText12" text="Status"/></Column>
                    <!-- <Column><Text text="{i18n>typ}"/></Column> -->
                    <Column id="_IDGenColumn33"><Text id="_IDGenText14" text="Created By"/></Column>
                    <Column id="_IDGenColumn34"><Text id="_IDGenText15" text="Created On"/></Column>
                    <Column ><Text text="Approved By"></Text></Column>
                    <Column ><Text text="Approved On"></Text></Column>
                </columns>
                
                <items>
                    <ColumnListItem id="_IDGenColumnListItem2">
                        <cells>
                            <!-- <Text text="{mainServiceModel>ReqId}"/> -->
                            <Link id="_IDGenLink" text="{mainServiceModel>ReqId}" press="ViewGroupNumbers" ariaHasPopup="Dialog"/>
                            <Text id="_IDGenText16" text="{mainServiceModel>Status}"/>
                            <!-- <Text text="{mainServiceModel>Type}"/> -->
                            <Text id="_IDGenText17" text="{mainServiceModel>CreatedBy}"/>
                            <Text id="_IDGenText18" text="{mainServiceModel>CreatedOn}"/>
                            <Text text="{mainServiceModel>ApprovedBy}"></Text>
                            <Text text="{mainServiceModel>ApprovedOn}"></Text>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </f:content>
        
    </f:DynamicPage>
</mvc:View>

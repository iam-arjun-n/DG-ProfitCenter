{
  "name": "MDGProfitCenter",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.12.12",
    "@sap-cloud-sdk/http-client": "^3.16.0",
    "@sap-cloud-sdk/resilience": "^3.16.0",
    "@sap/cds": "^7.9.5",
    "@sap/cds-hana": "^2.1.0",
    "@sap/hana-client": "^2.21.28",
    "@sap/xssec": "^3",
    "express": "^4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1.11.1",
    "@sap/cds-dk": "^8.9.11",
    "@sap/eslint-plugin-cds": "^3",
    "@sap/hdi-deploy": "4.9.5",
    "@sap/ux-specification": "^1.120.14",
    "cds-plugin-ui5": "^0.13.0",
    "eslint": "^9",
    "mbt": "^1.2.29",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-profitcenterinitiatorui": "cds watch --open mdg.profitcenter.ui.profitcenterinitiatorui/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy MDGProfitCenter --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "watch-pcapprover": "cds watch --open com.deloitte.mdg.profitcenter.approver1.pcapprover/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "cds": {
    "requires": {
      "[development]": {
        "auth": "mocked"
      },
      "[production]": {
        "auth": "xsuaa"
      },
      "db": "hana",
      "ZDEMP_BTP_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/ZDEMP_BTP_SRV",
        "credentials": {
          "destination": "DIM",
          "path": "/sap/opu/odata/sap/ZDEMP_BTP_SRV",
          "forwardAuthToken": true
        }
      },
      "hana": {
        "deploy-format": "hdbtable"
      }
    },
    "cov2app": {
      "plugin": true
    },
    "hana": {
      "deploy-format": "hdbtable"
    }
  },
  "workspaces": [
    "app/*"
  ]
}
